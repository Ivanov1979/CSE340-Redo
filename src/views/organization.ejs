<%- include('partials/header') %>

    <main>

        <% if (organizationDetails) { %>

            <h2>
                <%= organizationDetails.name %>
            </h2>

            <% if (organizationDetails.logo_filename) { %>

                <img src="/images/<%= organizationDetails.logo_filename %>" alt="<%= organizationDetails.name %> logo">

                <% } %>

                    <p>
                        <%= organizationDetails.description %>
                    </p>

                    <p>
                        <strong>Contact:</strong>
                        <%= organizationDetails.contact_email %>
                    </p>

                    <h3>Service Projects</h3>

                    <% if (projects && projects.length> 0) { %>

                        <ul>

                            <% projects.forEach(project=> { %>

                                <li>
                                    <a href="/project/<%= project.project_id %>">
                                        <%= project.title %>
                                    </a>
                                </li>

                                <% }) %>

                        </ul>

                        <% } else { %>

                            <p>
                                No service projects are currently associated with this organization.
                            </p>

                            <% } %>

                                <% } else { %>

                                    <h2>Organization Not Found</h2>

                                    <p>
                                        The requested organization could not be found.
                                    </p>

                                    <% } %>

    </main>

    <%- include('partials/footer') %>