<%- include('partials/header', { title }) %>

    <main>

        <section class="page-banner">

            <h1>
                <%= title %>
            </h1>

            <p>
                Meet our partner organizations dedicated to education,
                mathematics, and community development.
            </p>

        </section>

        <section class="organizations-container">

            <% organizations.forEach(org=> { %>

                <div class="organization-card">

                    <h3>
                        <a href="/organizations/<%= org.organization_id %>">
                            <%= org.name %>
                        </a>
                    </h3>

                    <p>
                        <%= org.description %>
                    </p>

                    <p>
                        <strong>Email:</strong>
                        <%= org.contact_email %>
                    </p>

                </div>

                <% }) %>

        </section>

        <p class="add-link">

            <a href="/organizations/new">
                Add a New Organization
            </a>

        </p>

    </main>

    <%- include('partials/footer') %>