<%- include("partials/header", { title }) %>

    <section class="page-banner">

        <h2>
            <%= project.title %>
        </h2>

    </section>

    <section class="organization-card">

        <p>
            <strong>Description:</strong>
            <%= project.description %>
        </p>

        <p>
            <strong>Date:</strong>
            <%= project.date ? new Date(project.date).toDateString() : "No date available" %>
        </p>

        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>

        <p>
            <strong>Organization:</strong>
            <a href="/organizations/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

    </section>

    <% if (session && session.user) { %>

        <% if (userIsVolunteer) { %>

            <p class="add-link">
                You are volunteering for this project.
            </p>

            <form action="/projects/<%= project.project_id %>/remove-volunteer" method="POST" class="add-link">
                <button type="submit" class="btn-submit">
                    Remove Me as Volunteer
                </button>
            </form>

            <% } else { %>

                <form action="/projects/<%= project.project_id %>/volunteer" method="POST" class="add-link">
                    <button type="submit" class="btn-submit">
                        Volunteer for this Project
                    </button>
                </form>

                <% } %>

                    <% } %>

                        <% if (session && session.user && session.user.role_name==="admin" ) { %>

                            <p class="add-link">
                                <a href="/edit-project/<%= project.project_id || project.id %>">
                                    Edit Project
                                </a>
                            </p>

                            <p class="add-link">
                                <a href="/new-project">
                                    Add a New Service Project
                                </a>
                            </p>

                            <% } %>

                                <p class="add-link">
                                    <a href="/projects">
                                        Return to Projects List
                                    </a>
                                </p>

                                <%- include("partials/footer") %>