<%- include("partials/header", { title }) %>

    <section class="page-banner">
        <h2>
            <%= project.title %>
        </h2>
    </section>

    <section class="organization-card">

        <p>
            <strong>Description:</strong>
            <%= project.description %>
        </p>

        <p>
            <strong>Date:</strong>
            <%= project.date.toDateString() %>
        </p>

        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>

        <p>
            <strong>Organization:</strong>
            <a href="/organizations/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

    </section>

    <p class="add-link">
        <a href="/edit-project/<%= project.project_id %>">
            Edit Project
        </a>
    </p>

    <p class="add-link">
        <a href="/projects/<%= project.project_id %>/categories">
            Assign Categories
        </a>
    </p>

    <p class="add-link">
        <a href="/new-project">
            Add a New Service Project
        </a>
    </p>

    <%- include("partials/footer") %>