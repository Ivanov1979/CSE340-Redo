<%- include('partials/header', { title }) %>

    <main>

        <section class="dashboard-container">

            <h1>
                Dashboard
            </h1>

            <p>
                <strong>Name:</strong>
                <%= name %>
            </p>

            <p>
                <strong>Email:</strong>
                <%= email %>
            </p>

            <% if (session && session.user && session.user.role_name==="admin" ) { %>

                <p>
                    <a href="/users">
                        View Registered Users
                    </a>
                </p>

                <% } %>

        </section>

        <section class="organizations-container">

            <h2>
                My Volunteer Projects
            </h2>

            <% if (volunteerProjects && volunteerProjects.length> 0) { %>

                <% volunteerProjects.forEach(project=> { %>

                    <div class="organization-card">

                        <h3>
                            <a href="/projects/<%= project.project_id %>">
                                <%= project.title %>
                            </a>
                        </h3>

                        <p>
                            <%= project.description %>
                        </p>

                        <p>
                            <strong>Date:</strong>
                            <%= project.date ? new Date(project.date).toDateString() : "No date available" %>
                        </p>

                        <p>
                            <strong>Location:</strong>
                            <%= project.location %>
                        </p>

                        <form action="/projects/<%= project.project_id %>/remove-volunteer?from=dashboard"
                            method="POST">
                            <button type="submit" class="btn-submit">
                                Remove Me as Volunteer
                            </button>
                        </form>

                    </div>

                    <% }) %>

                        <% } else { %>

                            <p>
                                You have not volunteered for any projects yet.
                            </p>

                            <% } %>

        </section>

    </main>

    <%- include('partials/footer') %>