<%- include("partials/header", { title }) %>

    <section class="page-banner">

        ```
        <h2>
            <%= title %>
        </h2>

        <p>
            View the next upcoming service projects and learn how each one connects
            to our partner organizations.
        </p>

        <% if ( session && session.user && session.user.role_name==="admin" ) { %>

            <p>

                <a class="button" href="/new-project">

                    Create New Project

                </a>

            </p>

            <% } %>
                ```

    </section>

    <section class="organizations-container">

        ```
        <% if (projects && projects.length> 0) { %>

            <% projects.forEach(project=> { %>

                <div class="organization-card">

                    <h3>

                        <a href="/projects/<%= project.project_id %>">

                            <%= project.title %>

                        </a>

                    </h3>

                    <p>
                        <%= project.description %>
                    </p>

                    <p>

                        <strong>Date:</strong>

                        <%= project.date ? new Date(project.date).toDateString() : "No date available" %>

                    </p>

                    <p>

                        <strong>Location:</strong>

                        <%= project.location %>

                    </p>

                    <p>

                        <strong>Organization:</strong>

                        <a href="/organizations/<%= project.organization_id %>">

                            <%= project.organization_name %>

                        </a>

                    </p>

                    <p>

                        <a href="/projects/<%= project.project_id %>">

                            View Details

                        </a>

                        <% if ( session && session.user && session.user.role_name==="admin" ) { %>

                            |

                            <a href="/edit-project/<%= project.project_id %>">

                                Edit Project

                            </a>

                            <% } %>

                    </p>

                </div>

                <% }) %>

                    <% } else { %>

                        <p>
                            No projects are available at this time.
                        </p>

                        <% } %>
                            ```

    </section>

    <%- include("partials/footer") %>