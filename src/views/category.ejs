<%- include("partials/header", { title }) %>

    <section class="page-banner">

        ```
        <h2>
            <%= category.name %>
        </h2>

        <p>
            Service projects connected to this category.
        </p>
        ```

    </section>

    <section class="organizations-container">

        ```
        <% projects.forEach(project=> { %>

            <div class="organization-card">

                <h3>

                    <a href="/projects/<%= project.project_id %>">

                        <%= project.title %>

                    </a>

                </h3>

                <p>

                    <%= project.description %>

                </p>

                <p>

                    <strong>Organization:</strong>

                    <a href="/organizations/<%= project.organization_id %>">

                        <%= project.organization_name %>

                    </a>

                </p>

            </div>

            <% }) %>
                ```

    </section>

    <% if ( session && session.user && session.user.role_name==="admin" ) { %>

        ```
        <p class="add-link">

            <a href="/edit-category/<%= category.category_id %>">

                Edit Category

            </a>

        </p>
        ```

        <% } %>

            <%- include("partials/footer") %>