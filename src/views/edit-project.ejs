<%- include('partials/header', { title }) %>

    <main>
        <section class="form-container">

            <h1>
                <%= title %>
            </h1>

            <form action="/edit-project/<%= project.project_id %>" method="POST">

                <div class="form-group">
                    <label for="organizationId">Organization</label>

                    <select id="organizationId" name="organizationId" required>
                        <% organizations.forEach(org=> { %>
                            <option value="<%= org.organization_id %>"
                                <%=Number(org.organization_id)===Number(project.organization_id) ? 'selected' : '' %>>
                                <%= org.name %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label for="title">Project Title</label>
                    <input type="text" id="title" name="title" value="<%= project.title %>" required maxlength="200">
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" required
                        maxlength="1000"><%= project.description %></textarea>
                </div>

                <div class="form-group">
                    <label for="location">Location</label>
                    <input type="text" id="location" name="location" value="<%= project.location %>" required
                        maxlength="200">
                </div>

                <div class="form-group">
                    <label for="date">Date</label>
                    <input type="date" id="date" name="date"
                        value="<%= project.date ? new Date(project.date).toISOString().split('T')[0] : '' %>" required>
                </div>

                <button type="submit" class="btn-submit">
                    Update Project
                </button>

            </form>

        </section>
    </main>

    <%- include('partials/footer') %>